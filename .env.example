# Frontend (browser-safe, bundled by Vite)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ---------------------------------------------------------------
# Edge Function secrets (server-side only)
# Set these via Supabase secrets — NOT as VITE_ browser vars.
#
# SMARTUSER_APP_ID=your-smartuser-app-id
# SMARTUSER_APP_SECRET=your-smartuser-app-secret
# SMARTUSER_ENV=PROD
# SMARTUSER_API_BASE_URL=https://api.smartuser.digitalvirgo.com
#
# IMPORTANT: SMARTUSER_APP_SECRET must NEVER be prefixed with VITE_
# It is a private server credential used only inside Edge Functions.
# ---------------------------------------------------------------
