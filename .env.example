# Frontend (browser-safe, bundled by Vite)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ---------------------------------------------------------------
# Supabase Edge Function secrets (server-side only).
# All SMARTUSER_* vars are Edge Function secrets.
# NEVER prefix with VITE_ — they must not be exposed to the browser.
#
# Required:
# SMARTUSER_APP_ID=your-smartuser-app-id
# SMARTUSER_APP_SECRET=your-smartuser-app-secret
# SMARTUSER_API_BASE_URL=https://api.smartuser.digitalvirgo.com
#
# Optional:
# SMARTUSER_ENV=PROD
#
# Path overrides (defaults shown). Update to match real SmartUser API docs.
# SMARTUSER_LOGIN_PATH=/auth/login
# SMARTUSER_SIGNUP_PATH=/auth/signup
# SMARTUSER_SESSION_PATH=/auth/session
# SMARTUSER_LOGOUT_PATH=/auth/logout
# ---------------------------------------------------------------
